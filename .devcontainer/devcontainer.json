{
    // 讓 VS Code 直接在「跑 Odoo 的容器」裡開發，
    // 編輯器即用容器內的 Python 3.9（已裝 odoo、openai、anthropic、
    // sentence-transformers、pypdf、python-docx、pymupdf 等），
    // 所有 import 都能正確解析、自動補全與跳定義。
    "name": "Odoo 16 AI Assistant",

    // 重用既有的 docker-compose 設定，附掛到 web 服務
    "dockerComposeFile": ["../docker-compose.yml"],
    "service": "web",

    // addons 已掛載於容器內此路徑（見 docker-compose web volumes）
    "workspaceFolder": "/mnt/extra-addons",

    // odoo:16 映像以 odoo 使用者執行
    "remoteUser": "odoo",

    // 關閉視窗時不要把整個 compose 停掉（保留你既有的執行環境）
    "shutdownAction": "none",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.languageServer": "Pylance",
                "python.analysis.extraPaths": ["/mnt/extra-addons"]
            }
        }
    }
}
